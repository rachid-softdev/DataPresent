# DataPresent - Production Secrets Template
# ==========================================
# Template pour les secrets de production
# Copy to .env.production.local and replace placeholders
# THIS FILE IS IGNORED BY GIT

# ==========================================
# DATABASE (NEON - PRODUCTION)
# ==========================================
DATABASE_URL=postgresql://neondb_owner:password@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb?channel_binding=require&sslmode=require

# ==========================================
# NEXTAUTH
# ==========================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-generated-secret-here

# ==========================================
# GOOGLE OAUTH
# ==========================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ==========================================
# ANTHROPIC (AI)
# ==========================================
ANTHROPIC_API_KEY=sk-ant-api03-xxx

# ==========================================
# STRIPE (LIVE KEYS)
# ==========================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_TEAM_PRICE_ID=price_xxx

# ==========================================
# CLOUDFLARE R2
# ==========================================
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_PUBLIC_URL=https://pub-r2.datapresent.com

# ==========================================
# REDIS (PRODUCTION - Upstash or managed)
# ==========================================
REDIS_URL=your-production-redis-url

# ==========================================
# EMAIL (RESEND)
# ==========================================
RESEND_API_KEY=re_xxx
EMAIL_FROM=DataPresent <noreply@datapresent.io>
RESEND_FROM_EMAIL=DataPresent <noreply@datapresent.io>

# ==========================================
# SECURITY
# ==========================================
CSRF_SECRET=your-csrf-secret-min-32-chars
ALLOWED_ORIGINS=https://datapresent.com,https://app.datapresent.com

# ==========================================
# VERCEL (auto-generated by `vercel link`)
# ==========================================
VERCEL_OIDC_TOKEN=...
VERCEL_ORG_ID=team_xxx
VERCEL_PROJECT_ID=prj_xxx
VERCEL_TOKEN=...