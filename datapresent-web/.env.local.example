# DataPresent - Local Development Secrets Template
# ==================================================
# Template pour les secrets de développement
# Copy to .env.local and replace placeholders
# THIS FILE IS IGNORED BY GIT

# ==========================================
# DATABASE
# ==========================================
DATABASE_URL=postgresql://dev:azerty123@localhost:5432/dev?schema=datapresent

# ==========================================
# NEXTAUTH
# ==========================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-generated-secret-here

# ==========================================
# GOOGLE OAUTH
# ==========================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ==========================================
# GITHUB OAUTH (optional)
# ==========================================
GITHUB_ID=your-github-id
GITHUB_SECRET=your-github-secret

# ==========================================
# ANTHROPIC (AI)
# ==========================================
ANTHROPIC_API_KEY=sk-ant-api03-xxx

# ==========================================
# STRIPE (TEST KEYS)
# ==========================================
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_TEAM_PRICE_ID=price_xxx

# ==========================================
# CLOUDFLARE R2
# ==========================================
R2_ACCOUNT_ID=your_access_key_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_PUBLIC_URL=https://pub-r2.datapresent.com

# ==========================================
# REDIS
# ==========================================
REDIS_URL=redis://localhost:6379

# ==========================================
# EMAIL - SMTP (MailHog)
# ==========================================
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=mailhog
SMTP_PASS=mailhog

# ==========================================
# EMAIL - RESEND (optional)
# ==========================================
RESEND_API_KEY=re_xxx

# ==========================================
# GOOGLE SHEETS (optional)
# ==========================================
GOOGLE_SHEETS_CLIENT_EMAIL=your-sheets-client-email@project.iam.gserviceaccount.com
GOOGLE_SHEETS_PRIVATE_KEY=your-private-key

# ==========================================
# SECURITY
# ==========================================
CSRF_SECRET=your-csrf-secret-min-32-chars
ALLOWED_ORIGINS=https://datapresent.com,https://app.datapresent.com,https://localhost:3000

# ==========================================
# VERCEL (optional - for local vercel commands)
# ==========================================
VERCEL_OIDC_TOKEN=...
VERCEL_ORG_ID=team_xxx
VERCEL_PROJECT_ID=prj_xxx
VERCEL_TOKEN=...