{
  "name": "datapresent-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:complete": "node scripts/start-dev-complete.js",
    "dev:mailhog": "node scripts/start-dev-with-mailhog.js",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --no-warn-ignored",
    "lint:staged": "eslint --no-warn-ignored",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force && prisma db push",
    "stripe:setup": "node scripts/setup-stripe-cli.js",
    "stripe:stop": "node scripts/stop-stripe-cli.js",
    "stripe:test-webhooks": "node scripts/stripe-test-webhooks.js",
    "stripe:products": "npx tsx scripts/create-stripe-products.ts",
    "mailhog:setup": "node scripts/setup-mailhog.js",
    "mailhog:start": "node scripts/setup-mailhog.js",
    "mailhog:stop": "node scripts/stop-mailhog.js",
    "worker:dev": "npx tsx scripts/start-workers.ts",
    "worker:start": "npx tsx scripts/start-workers.ts",
    "check:env": "npx tsx scripts/check-env.ts",
    "push:env": "npx tsx scripts/push-env.ts",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:authenticated": "playwright test --project=authenticated",
    "test:api": "playwright test --project=api",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:watch": "vitest --config vitest.integration.config.ts",
    "qa": "node scripts/qa-web.js",
    "qa:headless": "node scripts/qa-web.js -- --headless",
    "format": "prettier --write \"app/**/*.{ts,tsx,js,jsx,json,css}\" \"components/**/*.{ts,tsx,js,jsx}\"",
    "format:check": "prettier --check \"app/**/*.{ts,tsx,js,jsx,json,css}\" \"components/**/*.{ts,tsx,js,jsx}\"",
    "blog:generate": "npx tsx scripts/generate-blog-posts.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@auth/prisma-adapter": "^2.11.2",
    "@aws-sdk/client-s3": "^3.1063.0",
    "@aws-sdk/s3-request-presigner": "^3.1057.0",
    "@datapresent/ui": "workspace:*",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.4.0",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/client": "^5.22.0",
    "@sentry/nextjs": "^10.53.1",
    "@sparticuz/chromium": "^123.0.0",
    "@stripe/stripe-js": "^9.7.0",
    "bullmq": "^5.77.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "docx": "^9.6.1",
    "dompurify": "^3.2.0",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.40.0",
    "googleapis": "^173.0.0",
    "ioredis": "^5.10.1",
    "jsdom": "^29.1.1",
    "lru-cache": "^11.5.1",
    "lucide-react": "^1.14.0",
    "next": "16.2.7",
    "next-auth": "^5.0.0-beta.31",
    "next-intl": "^4.13.0",
    "nodemailer": "^8.0.10",
    "pdf-parse": "^2.4.5",
    "pptxgenjs": "^4.0.1",
    "puppeteer-core": "^25.1.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.75.0",
    "recharts": "^3.8.1",
    "resend": "^6.12.2",
    "sonner": "^2.0.7",
    "stripe": "^22.2.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/cli": "^0.1.14",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^20.19.39",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.7",
    "dotenv": "^17.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-security": "^3.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "prisma": "^5.22.0",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^6",
    "vitest": "^4.1.8"
  }
}
