# DataPresent - Environment Variables Template
# ==============================================
# Template global pour onboarding
# IMPORTANT: Ce fichier contient des placeholders - remplacez par vos vraies valeurs

# ==========================================
# SECTION 1: NODE ENVIRONMENT
# ==========================================
NODE_ENV=development

# ==========================================
# SECTION 2: APP CONFIGURATION
# ==========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# ==========================================
# SECTION 3: DATABASE
# ==========================================
DATABASE_URL=postgresql://user:password@host:5432/dbname?schema=datapresent

# ==========================================
# SECTION 4: NEXTAUTH
# ==========================================
# Required - generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret

# ==========================================
# SECTION 5: STRIPE (Payment)
# ==========================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe Price IDs (non-sensibles)
STRIPE_PRICE_STARTER_MONTHLY=price_xxx
STRIPE_PRICE_PRO_MONTHLY=price_xxx

# ==========================================
# SECTION 6: AI PROVIDERS
# ==========================================
ANTHROPIC_API_KEY=sk-ant-api03-xxx

# ==========================================
# SECTION 7: GOOGLE OAUTH
# ==========================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth (optional)
# GITHUB_ID=your-github-id
# GITHUB_SECRET=your-github-secret

# ==========================================
# SECTION 8: EMAIL (RESEND)
# ==========================================
RESEND_API_KEY=re_xxx
EMAIL_FROM=DataPresent <noreply@datapresent.io>
RESEND_FROM_EMAIL=DataPresent <noreply@datapresent.io>

# ==========================================
# SECTION 9: EMAIL (SMTP - DEV ONLY)
# ==========================================
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=mailhog
SMTP_PASS=mailhog

# ==========================================
# SECTION 10: CLOUD STORAGE (R2)
# ==========================================
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=datapresent
R2_PUBLIC_URL=https://pub-r2.datapresent.com

# ==========================================
# SECTION 11: REDIS (BullMQ)
# ==========================================
REDIS_URL=redis://localhost:6379

# ==========================================
# SECTION 12: SECURITY
# ==========================================
CSRF_SECRET=your-csrf-secret-min-32-chars
ALLOWED_ORIGINS=https://datapresent.com,https://app.datapresent.com,https://localhost:3000

# ==========================================
# SECTION 13: COMPANY INFO (INVOICING)
# ==========================================
COMPANY_NAME=PromptBearer
COMPANY_ADDRESS=12 Rue de la Tech, 75001 Paris, France
COMPANY_SIREN=123456789
COMPANY_SIRET=12345678900012
COMPANY_CAPITAL=1000
COMPANY_RCS=Paris 123 456 789
COMPANY_EMAIL=contact@promptbearer.com
COMPANY_TVA=FR12345678901

# ==========================================
# SECTION 14: GOOGLE SHEETS (OPTIONAL)
# ==========================================
GOOGLE_SHEETS_CLIENT_EMAIL=your-sheets-client-email@project.iam.gserviceaccount.com
GOOGLE_SHEETS_PRIVATE_KEY=your-private-key

# ==========================================
# SECTION 15: VERCEL (AUTO-GENERATED)
# ==========================================
# These are auto-generated by `vercel link` command
VERCEL_OIDC_TOKEN=...
VERCEL_ORG_ID=team_xxx
VERCEL_PROJECT_ID=prj_xxx
VERCEL_TOKEN=...