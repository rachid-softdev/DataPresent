# DataPresent - Default Environment Variables
# ==========================================
# Valeurs par défaut partagées (non-sensibles)
# Chargées dans tous les environnements

# Node environment (surchargeable par .env.development ou .env.production)
NODE_ENV=development

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Stripe Publishable Key (non-sensible)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Stripe Price IDs (non-sensibles - peuvent être commitées)
STRIPE_PRICE_STARTER_MONTHLY=price_xxx
STRIPE_PRICE_PRO_MONTHLY=price_xxx

# Company Information (non-sensible - infos légales publiques)
COMPANY_NAME=PromptBearer
COMPANY_ADDRESS=12 Rue de la Tech, 75001 Paris, France
COMPANY_SIREN=123456789
COMPANY_SIRET=12345678900012
COMPANY_TVA=FR12345678901
COMPANY_CAPITAL=1000
COMPANY_RCS=Paris 123 456 789
COMPANY_EMAIL=contact@promptbearer.com

# Cloudflare R2 (non-sensibles)
R2_BUCKET_NAME=datapresent