# DataPresent Extension - Production Secrets Template
# ==================================================
# Template pour les secrets de production
# Copy to .env.production.local and replace placeholders
# THIS FILE IS IGNORED BY GIT

# ==========================================
# AUTH (OAUTH - PROD)
# ==========================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ==========================================
# BACKEND API (PROD)
# ==========================================
API_BASE_URL=https://datapresent.com/api
API_SECRET=your-api-secret

# ==========================================
# CHROME STORAGE (PROD)
# ==========================================
CHROME_STORAGE_KEY=your-chrome-storage-encryption-key

# ==========================================
# ANALYTICS (PROD)
# ==========================================
NEXT_PUBLIC_MIXPANEL_TOKEN=your-mixpanel-prod-token