# DataPresent Extension - Default Environment Variables
# ======================================================
# Valeurs par défaut partagées (non-sensibles)
# Chargées dans tous les environnements

# Node environment
NODE_ENV=development

# ==========================================
# APPLICATION CONFIGURATION
# ==========================================
NEXT_PUBLIC_APP_NAME=DataPresent Extension
NEXT_PUBLIC_APP_VERSION=1.0.0

# ==========================================
# API CONFIGURATION
# ==========================================
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==========================================
# STRIPE (NON-SENSIBLE)
# ==========================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ==========================================
# EXTENSION CONFIGURATION
# ==========================================
# Extension ID (auto-generated on build)
NEXT_PUBLIC_EXTENSION_ID=your-extension-id

# ==========================================
# FEATURE FLAGS (NON-SENSIBLE)
# ==========================================
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_CONTEXT_MENU=true