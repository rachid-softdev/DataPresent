# DataPresent Extension - Local Development Secrets Template
# ============================================================
# Template pour les secrets de développement
# Copy to .env.local and replace placeholders
# THIS FILE IS IGNORED BY GIT

# ==========================================
# AUTH (OAUTH)
# ==========================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ==========================================
# BACKEND API
# ==========================================
API_BASE_URL=http://localhost:3000/api
API_SECRET=your-api-secret

# ==========================================
# CHROME STORAGE
# ==========================================
CHROME_STORAGE_KEY=your-chrome-storage-encryption-key

# ==========================================
# ANALYTICS (OPTIONAL)
# ==========================================
NEXT_PUBLIC_MIXPANEL_TOKEN=your-mixpanel-dev-token