# DataPresent Desktop - Environment Variables Template
# ====================================================
# Template global pour onboarding
# IMPORTANT: Ce fichier contient des placeholders - remplacez par vos vraies valeurs

# ==========================================
# NODE ENVIRONMENT
# ==========================================
NODE_ENV=development

# ==========================================
# APPLICATION CONFIGURATION
# ==========================================
NEXT_PUBLIC_APP_NAME=DataPresent
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==========================================
# API CONFIGURATION
# ==========================================
NEXT_PUBLIC_API_URL=http://localhost:3000/api
API_BASE_URL=http://localhost:3000/api
API_SECRET=your-api-secret

# ==========================================
# AUTH
# ==========================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ==========================================
# STRIPE
# ==========================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ==========================================
# WINDOW CONFIGURATION
# ==========================================
NEXT_PUBLIC_DESKTOP_DEFAULT_WIDTH=1200
NEXT_PUBLIC_DESKTOP_DEFAULT_HEIGHT=800
NEXT_PUBLIC_DESKTOP_MIN_WIDTH=800
NEXT_PUBLIC_DESKTOP_MIN_HEIGHT=600

# ==========================================
# FEATURE FLAGS
# ==========================================
NEXT_PUBLIC_ENABLE_TRAY=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_LOG_LEVEL=debug
NEXT_PUBLIC_DEBUG_MODE=false
NEXT_PUBLIC_ENABLE_DEVTOOLS=true

# ==========================================
# ELECTRON CONFIGURATION
# ==========================================
ELECTRON_ENABLE_LOGGING=true
ELECTRON_STORE_KEY=your-electron-store-encryption-key

# ==========================================
# ANALYTICS (OPTIONAL)
# ==========================================
NEXT_PUBLIC_MIXPANEL_TOKEN=your-mixpanel-token