# DataPresent Desktop - Production Secrets Template
# ================================================
# Template pour les secrets de production
# Copy to .env.production.local and replace placeholders
# THIS FILE IS IGNORED BY GIT

# ==========================================
# AUTH (OAUTH - PROD)
# ==========================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ==========================================
# BACKEND API (PROD)
# ==========================================
API_BASE_URL=https://datapresent.com/api
API_SECRET=your-api-secret

# ==========================================
# ELECTRON STORE (PROD)
# ==========================================
ELECTRON_STORE_KEY=your-electron-store-encryption-key

# ==========================================
# ANALYTICS (PROD)
# ==========================================
NEXT_PUBLIC_MIXPANEL_TOKEN=your-mixpanel-prod-token