# DataPresent Mobile - Environment Variables Template
# ====================================================
# Template global pour onboarding
# IMPORTANT: Ce fichier contient des placeholders - remplacez par vos vraies valeurs

# ==========================================
# NODE ENVIRONMENT
# ==========================================
NODE_ENV=development

# ==========================================
# API CONFIGURATION
# ==========================================
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==========================================
# AUTH
# ==========================================
NEXT_PUBLIC_AUTH_PROVIDERS=google,email
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ==========================================
# STRIPE
# ==========================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ==========================================
# API SECRET (FOR MOBILE)
# ==========================================
API_BASE_URL=http://localhost:3000/api
API_SECRET=your-api-secret

# ==========================================
# FEATURE FLAGS
# ==========================================
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_OFFLINE_MODE=true
NEXT_PUBLIC_LOG_LEVEL=debug
NEXT_PUBLIC_DEBUG_MODE=false

# ==========================================
# ANALYTICS (OPTIONAL)
# ==========================================
NEXT_PUBLIC_MIXPANEL_TOKEN=your-mixpanel-token