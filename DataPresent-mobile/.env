# DataPresent Mobile - Default Environment Variables
# =====================================================
# Valeurs par défaut partagées (non-sensibles)
# Chargées dans tous les environnements

# Node environment
NODE_ENV=development

# ==========================================
# API CONFIGURATION
# ==========================================
# Backend API URL (development)
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==========================================
# STRIPE (MOBILE - NON-SENSIBLE)
# ==========================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ==========================================
# AUTH CONFIGURATION
# ==========================================
# Mobile Auth configuration
NEXT_PUBLIC_AUTH_PROVIDERS=google,email

# ==========================================
# FEATURE FLAGS (NON-SENSIBLE)
# ==========================================
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_OFFLINE_MODE=true