{
  "name": "datapresent",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter datapresent-web dev",
    "start-dev-complete": "pnpm --filter datapresent-web dev:complete",
    "build": "pnpm --filter datapresent-web build",
    "start": "pnpm --filter datapresent-web start",
    "lint": "pnpm --filter datapresent-web lint",
    "test": "pnpm --filter datapresent-web test",
    "test:unit": "pnpm --filter datapresent-web test:unit",
    "db:generate": "pnpm --filter datapresent-web db:generate",
    "db:push": "pnpm --filter datapresent-web db:push",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "pnpm run format:check \u0026\u0026 pnpm run lint",
    "prepare": "husky",
    "web:dev": "pnpm --filter datapresent-web dev",
    "web:build": "pnpm --filter datapresent-web build",
    "web:start": "pnpm --filter datapresent-web start",
    "web:test": "pnpm --filter datapresent-web test",
    "web:lint": "pnpm --filter datapresent-web lint",
    "web:typecheck": "pnpm --filter datapresent-web typecheck",
    "check-env": "pnpm --filter datapresent-web check-env",
    "push-env": "pnpm --filter datapresent-web push-env",
    "workers:dev": "pnpm --filter workers dev",
    "workers:build": "pnpm --filter workers build",
    "workers:start": "pnpm --filter workers start",
    "workers:typecheck": "pnpm --filter workers typecheck",
    "workers:prisma-generate": "pnpm --filter workers prisma:generate",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset tag",
    "ci:release": "pnpm changeset version \u0026\u0026 pnpm install --no-frozen-lockfile \u0026\u0026 pnpm build \u0026\u0026 pnpm changeset tag"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "@changesets/cli": "^2.27.0",
    "@changesets/changelog-github": "^0.5.0"
  },
  "lint-staged": {
    "*": [
      "biome format --write --no-errors-on-unmatched --files-ignore-unknown=true"
    ],
    "*.{ts,tsx}": [
      "pnpm --filter datapresent-web lint:staged"
    ]
  }
}
